{
  "expo": {
    "name": "FBLA Member App",
    "slug": "fbla-member-app",
    "version": "1.0.0",
    "scheme": "fbla",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#101114"
    },
    "ios": {
      "supportsTablet": true,
      "newArchEnabled": true,
      "bundleIdentifier": "com.fblamember.app"
    },
    "android": {
      "newArchEnabled": true,
      "package": "com.fblamember.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#101114"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-splash-screen",
      "expo-sqlite"
    ]
  }
}
